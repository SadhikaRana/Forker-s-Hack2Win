<?xml version="1.0" encoding="UTF-8"?>
<Response>

  <!-- Welcome -->
  <Say voice="alice">
    Welcome to Smart Pay offline payment system.
  </Say>

  <!-- Payment Details -->
  <Say>
    You are about to pay 500 rupees to Merchant ABC.
  </Say>

  <!-- User Input -->
  <Gather numDigits="1" timeout="5">
    <Say>Press 1 to confirm payment.</Say>
    <Say>Press 2 to cancel transaction.</Say>
  </Gather>

  <!-- Default / Simulation Response -->
  <Say>
    Processing your request.
  </Say>
  <Say>
    Your payment has been successfully completed.
  </Say>
  <Say>
    Thank you for using Smart Pay.
  </Say>

</Response>
